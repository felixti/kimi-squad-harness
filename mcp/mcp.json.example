{
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY_HERE"
      }
    },
    "grep": {
      "url": "https://mcp.grep.app"
    },
    "dotcontext": {
      "command": "npx",
      "args": ["-y", "@dotcontext/mcp@latest", "serve", "--repo-path", "."]
    }
  }
}
